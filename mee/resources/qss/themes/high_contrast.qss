QFrame#Card {
    background-color: #000000;
    border: 1px solid #ffffff;
    border-radius: 0;
    padding: 18px;
}

QStatusBar {
    background: #000000;
    color: #ffffff;
    border-top: 1px solid #ffffff;
}

QListWidget#NavList {
    background: #000000;
    border-right: 1px solid #ffffff;
}

QListWidget#NavList::item {
    padding: 14px 18px;
    color: #ffffff;
}

QListWidget#NavList::item:selected {
    background-color: #ffffff;
    color: #000000;
}
